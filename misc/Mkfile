PROGS =	bidle			\
	flash			\
	pinentry-dmenu2		\
	slowcat

## Installation directory
PREFIX ?= /usr/local

## Installation directory for binaries
BINPREFIX ?= ${PREFIX}/bin

## Build ${PROGS:J, }
all: ${PROGS}

## Remove build artifacts for ${PROGS:J, }
clean:
	rm -f ${PROGS:F}

## Install ${PROGS:J, } into ${DESTDIR}${PREFIX}
install: ${PROGS}
	mkdir -p ${DESTDIR}${BINPREFIX}
	cp -f ${PROGS:F} ${DESTDIR}${BINPREFIX}/

bidle: bidle.c
	${CC} -o $@ bidle.c ${CFLAGS} ${CPPFLAGS} `pkg-config --cflags --libs x11 xscrnsaver` ${LDFLAGS}
